{
  "apps": [
    {
      "name": "openclaw-gateway",
      "script": "dist/server.js",
      "cwd": "./gateway",
      "instances": 1,
      "exec_mode": "fork",
      "watch": false,
      "autorestart": true,
      "max_restarts": 10,
      "restart_delay": 3000,
      "env": {
        "NODE_ENV": "production",
        "OPENCLAW_GATEWAY_PORT": "18789",
        "OPENCLAW_GATEWAY_HOST": "127.0.0.1"
      },
      "env_production": {
        "NODE_ENV": "production"
      },
      "error_file": "/app/work/logs/bypass/gateway-error.log",
      "out_file": "/app/work/logs/bypass/gateway-out.log",
      "log_file": "/app/work/logs/bypass/gateway.log",
      "time": true
    },
    {
      "name": "openclaw-web",
      "script": "node_modules/next/dist/bin/next",
      "args": "start -p 5000",
      "cwd": ".",
      "instances": 1,
      "exec_mode": "fork",
      "watch": false,
      "autorestart": true,
      "max_restarts": 10,
      "restart_delay": 3000,
      "env": {
        "NODE_ENV": "production",
        "PORT": "5000"
      },
      "error_file": "/app/work/logs/bypass/web-error.log",
      "out_file": "/app/work/logs/bypass/web-out.log",
      "log_file": "/app/work/logs/bypass/web.log",
      "time": true
    }
  ]
}
