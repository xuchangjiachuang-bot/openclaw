# ==================== LLM Provider API Keys ====================

# OpenAI (GPT-4o, GPT-4o-mini, etc.)
OPENAI_API_KEY=sk-your-openai-api-key

# Anthropic (Claude 3.5 Sonnet, Claude 3 Opus, etc.)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# DeepSeek (DeepSeek Chat, DeepSeek Coder)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# Kimi / Moonshot (Moonshot V1)
KIMI_API_KEY=your-kimi-api-key

# Coze (Coze Bot)
COZE_API_KEY=your-coze-api-key
COZE_BOT_ID=your-coze-bot-id

# OpenAI Codex (ChatGPT Subscription)
# 通过OAuth获取: https://auth.openai.com/authorize
OPENAI_CODEX_ACCESS_TOKEN=your-codex-access-token
OPENAI_CODEX_REFRESH_TOKEN=your-codex-refresh-token

# ==================== Gateway Configuration ====================

# Gateway安全Token（可选，用于设备配对认证）
OPENCLAW_GATEWAY_TOKEN=your-secure-gateway-token

# Gateway端口（默认18789）
OPENCLAW_GATEWAY_PORT=18789

# Gateway主机（默认127.0.0.1）
OPENCLAW_GATEWAY_HOST=127.0.0.1

# 状态存储目录（默认~/.openclaw）
OPENCLAW_STATE_DIR=/root/.openclaw

# ==================== Channel Configuration ====================

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Slack Bot
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_APP_TOKEN=xapp-your-slack-app-token

# Discord Bot
DISCORD_BOT_TOKEN=your-discord-bot-token

# WhatsApp Business
WHATSAPP_PHONE_ID=your-phone-id
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token

# ==================== Optional Services ====================

# Embedding服务（用于RAG）
EMBEDDING_API_KEY=your-embedding-api-key

# 对象存储（用于文件存储）
OSS_ACCESS_KEY=your-oss-access-key
OSS_SECRET_KEY=your-oss-secret-key
OSS_BUCKET=your-bucket-name
OSS_ENDPOINT=your-oss-endpoint

# ==================== Development ====================

# Next.js环境
NEXT_PUBLIC_GATEWAY_URL=ws://127.0.0.1:18789
